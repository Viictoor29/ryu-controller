{
  "name": "topologia-con-delay",
  "switches": [
    {"name": "s1", "dpid": "1"},
    {"name": "s2", "dpid": "2"}
  ],
  "hosts": [
    {
      "name": "h1",
      "ip": "10.0.0.1/24",
      "mac": "00:00:00:00:00:01",
      "switch": "s1",
      "switch_port": 1
    },
    {
      "name": "h2",
      "ip": "10.0.0.2/24",
      "mac": "00:00:00:00:00:02",
      "switch": "s2",
      "switch_port": 1
    }
  ],
  "links": [
    {
      "type": "switch-link",
      "src": {"node": "s1", "dpid": "1", "port_no": 2},
      "dst": {"node": "s2", "dpid": "2", "port_no": 2}
    }
  ],
  "policies": {
    "disabled_links": [],
    "tc": [
      {
        "type": "link",
        "src": {"dpid": "1", "port_no": 2},
        "dst": {"dpid": "2", "port_no": 2},
        "delay": "50ms",
        "loss": 0,
        "bandwidth": "10Mbit"
      }
    ],
    "blocked_ips": []
  },
  "options": {
    "apply_to_mininet": true,
    "reset_controller": true,
    "wait": true,
    "wait_hosts": true,
    "apply_policies": true,
    "pingall": true,
    "timeout": 40
  }
}